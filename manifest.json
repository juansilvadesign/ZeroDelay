{
   "action": {
      "default_popup": "popup.html"
   },
   "author": {
      "email": "joao@solitus.com.br"
   },
   "background": {
      "service_worker": "background.js",
      "type": "module"
   },
   "content_scripts": [ {
      "all_frames": true,
      "js": [ "content.js" ],
      "matches": [ "https://www.youtube.com/*" ],
      "run_at": "document_start"
   } ],
   "default_locale": "en",
   "description": "__MSG_appDesc__",
   "icons": {
      "128": "icons/128.png",
      "16": "icons/16.png",
      "48": "icons/48.png"
   },
   "manifest_version": 3,
   "name": "ZeroDelay",
   "options_ui": {
      "open_in_tab": true,
      "page": "popup.html"
   },
   "permissions": [ "alarms", "storage" ],
   "version": "1.1",
   "web_accessible_resources": [ {
      "matches": [ "https://www.youtube.com/*" ],
      "resources": [ "common.js", "inject.js" ]
   } ]
}
